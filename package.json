{
  "name": "agent-monitor",
  "version": "1.0.1",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "relay",
    "client"
  ],
  "scripts": {
    "dev": "npm run build -w shared && concurrently \"npm run dev -w shared\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build -w shared && npm run build:client && npm run build:server",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "test": "npm run test -w shared && npm run test -w server && npm run test -w client",
    "test:shared": "cd shared && npm test",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitepress": "^1.6.4"
  }
}
